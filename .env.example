# Flask settings
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=replace_with_a_random_secure_hex_key_in_production

# SQLite database local path (optional, defaults to database.db)
# DATABASE_PATH=database.db

# PostgreSQL database URI (required for Render/Railway/Ubuntu Server postgres setups)
# DATABASE_URL=postgresql://postgres_user:postgres_password@localhost:5432/finance_db
